#!/usr/bin/env node

/**
 * AndreClaw — Terminal de IA com qualquer modelo
 *
 * Se dist/cli.mjs existe (compilado), roda ele.
 * Caso contrário, avisa o usuário pra compilar primeiro ou usar `bun run dev`.
 */

import { existsSync, mkdirSync, readFileSync } from 'fs'
import { join, dirname } from 'path'
import { homedir } from 'os'
import { fileURLToPath, pathToFileURL } from 'url'

// AndreClaw usa seu proprio diretorio de config (~/.andreclaw)
// separado do Claude Code (~/.claude)
const andreClawDir = join(homedir(), '.andreclaw')
if (!existsSync(andreClawDir)) {
  mkdirSync(andreClawDir, { recursive: true })
}
process.env.CLAUDE_CONFIG_DIR = andreClawDir

// Auto-cd pro vault salvo (se existir e nao foi passado argumento de diretorio)
const vaultPathFile = join(andreClawDir, '.vault-path')
if (existsSync(vaultPathFile) && !process.argv.includes('-p') && !process.argv.includes('--project')) {
  const savedVault = readFileSync(vaultPathFile, 'utf8').trim()
  if (savedVault && existsSync(savedVault)) {
    process.chdir(savedVault)
  }
}

const __dirname = dirname(fileURLToPath(import.meta.url))
const distPath = join(__dirname, '..', 'dist', 'cli.mjs')

if (existsSync(distPath)) {
  await import(pathToFileURL(distPath).href)
} else {
  console.error(`
  andreclaw: dist/cli.mjs não encontrado.

  Compile primeiro:
    bun run build

  Ou rode direto com Bun:
    bun run dev

  Veja README.md pras instruções de setup.
`)
  process.exit(1)
}
